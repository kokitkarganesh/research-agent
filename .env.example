# Serper.dev — get a key at https://serper.dev
SERPER_API_KEY=

# OpenRouter — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Used in OpenRouter's HTTP-Referer header (optional, defaults to localhost)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Discord integration (bonus feature — added later)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
